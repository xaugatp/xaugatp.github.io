# Auto detect text files and perform LF normalization
* text=auto

# Binary files — no line ending conversion, no diff
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.pdf  binary
*.svg  text eol=lf

# Web source files — enforce LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
